# OTLab — primary virtualization topology TEMPLATE.
#
# Rendered to otlab.clab.yaml by scripts/render-topology.sh, which
# substitutes the first three octets of the DMZ + PCN subnets using
# values from /etc/otlab/student.env:
#
#   subnet  single-Pi default   classroom student N
#   ------  -----------------   ---------------------
#   DMZ     192.168.75          10.75.N
#   PCN     10.20.30            10.30.N
#
# (Placeholder details are in scripts/render-topology.sh — they're not
# repeated here so the rendered yaml's header reads cleanly.)
#
# DO NOT EDIT the rendered otlab.clab.yaml directly — your changes will
# be overwritten on the next render. Edit this .tmpl file instead.
#
# Same topology semantics as before:
#   Builds the entire DMZ + PCN as containers, with a router/firewall
#   container enforcing the conduit between zones — same architectural
#   shape every real Purdue-aligned OT shop runs.
#
#   V1 scope:    firewall + dual virtual OpenPLC + sensor-sim + DNP3 + dashboard
#   V2.x added:  modbus-master + Suricata IDS + physical Pi macvlan
#   V2.y added:  per-zone DHCP + DNS forwarder inside the firewall
#   V3 adds:     Authentik, Ignition, Guacamole, CODESYS
#
# Deploy:   sudo containerlab deploy   -t virtual/topologies/otlab.clab.yaml
# Destroy:  sudo containerlab destroy  -t virtual/topologies/otlab.clab.yaml
# Inspect:  sudo containerlab inspect  -t virtual/topologies/otlab.clab.yaml

name: otlab

mgmt:
  network: clab-otlab-mgmt
  ipv4-subnet: 172.20.20.0/24

topology:
  defaults:
    kind: linux

  # ───────────────────────────────────────────────────────────────────────
  # Bridges — one per Purdue zone. ContainerLab creates each as a Linux
  # bridge in the host's network namespace. Containers attach via veth
  # pairs (declared as links below).
  # ───────────────────────────────────────────────────────────────────────
  kinds:
    bridge:
      group: zones

  nodes:

    # ── Zone bridges ────────────────────────────────────────────────────
    dmz-br0:
      kind: bridge
      # Industrial DMZ — Level 3.5
      # __DMZ_NET__.0/24
      labels:
        zone: dmz
        purdue: "L3.5"

    pcn-br0:
      kind: bridge
      # Process Control Network — Levels 1 & 2
      # __PCN_NET__.0/24 (matches the physical L1 segment IP plan so V2
      # macvlan-integration with the physical Pis is just a plug-in)
      labels:
        zone: pcn
        purdue: "L1/L2"

    # ── Firewall: the conduit between DMZ and PCN ───────────────────────
    fw-dmz-pcn:
      kind: linux
      image: otlab/firewall:latest
      labels:
        zone: conduit
        purdue: "L3.5↔L2/1"
      # Three interfaces:
      #   eth1 -> dmz-br0  (__DMZ_NET__.1/24, gateway for DMZ)
      #   eth2 -> pcn-br0  (__PCN_NET__.1/24,    gateway for PCN)
      #   eth0 -> mgmt     (clab-otlab-mgmt, for image pulls + tailscale)
      binds:
        # State exporter writes iptables.json + conntrack.txt every 5s.
        # Also dnsmasq's DNS query log lives here (redirected from its
        # default /var/log/dnsmasq-fw.log via DNS_LOG_FILE env). Single
        # shared dir keeps the dashboard's bind list simple.
        - /var/lib/otlab/fw-state:/var/lib/otlab/fw-state
      env:
        DNS_LOG_FILE: "/var/lib/otlab/fw-state/dnsmasq-fw.log"
        # Per-student subnets so start-firewall.sh inside the container
        # writes FORWARD rules that match the actual addressing. Without
        # these the script falls back to the single-Pi defaults
        # (192.168.75.0/24 / 10.20.30.0/24) and every packet in a
        # per-student deploy falls through to the default DROP.
        DMZ_NET: "__DMZ_NET__.0/24"
        PCN_NET: "__PCN_NET__.0/24"
      exec:
        - ip link set eth1 up
        - ip link set eth2 up
        - ip addr add __DMZ_NET__.1/24 dev eth1
        - ip addr add __PCN_NET__.1/24    dev eth2
        - sysctl -w net.ipv4.ip_forward=1
        - /opt/otlab-firewall/start-firewall.sh

    # ── DMZ services (Level 3.5) ────────────────────────────────────────
    dashboard:
      kind: linux
      image: otlab/dashboard:latest
      labels:
        zone: dmz
        purdue: "L3"
        service: otlab-dashboard
      ports:
        - 8000:8000     # exposed to the Pi host so external operators reach it
      env:
        DASH_USER: otlab
        DASH_PASS: "P@ssw0rd!"
        # OTLAB_PHYSICAL=1 lights up the dashboard cards for the physical
        # Pis (l1-plc-01 .47, l1-hp-01 .48) + Conpot personas (.50/.51/.52)
        # — they're macvlan-bridged into pcn-br0 via a USB NIC (eth1).
        #
        # Default is "0" (single-Pi standalone mode) so the dashboard
        # stays clean when no physical Pis are present. Set to "1" once
        # you've bootstrapped l1-plc-01 + l1-hp-01 and enabled eth1 in
        # /etc/otlab/bridge-attach.conf — see docs/setup-from-scratch.md
        # Stage 2 (physical expansion).
        OTLAB_PHYSICAL: "0"
        # Per-student subnet overrides. Without these, the dashboard hangs
        # in a connect-retry loop against the single-Pi default 10.20.30.70
        # (sensor-sim) and never serves the /api/status endpoint, which
        # makes the dashboard appear DOWN in the teacher Links Hub.
        OTLAB_LAB_HOSTS: |
          {
            "sensor-sim":      "__PCN_NET__.70",
            "dnp3":            "__PCN_NET__.71",
            "modbus-master":   "__PCN_NET__.43",
            "plc-1-virt":      "__PCN_NET__.60",
            "plc-2-virt":      "__PCN_NET__.61",
            "modbus-gateway":  "__PCN_NET__.180",
            "fw-dmz-pcn":      "__DMZ_NET__.1",
            "fw-dmz-pcn-pcn":  "__PCN_NET__.1",
            "dhcp-dmz":        "__DMZ_NET__.2",
            "dhcp-pcn":        "__PCN_NET__.2",
            "l3-mon-01":       "__DMZ_NET__.40"
          }
        SENSOR_SIM_CTRL: "http://__PCN_NET__.70:5021/control"
        # ESP32 the gateway polls. Per-student override: set per-class
        # to the student's own ESP32 once flashed (e.g. 10.20.30.202).
        # Default to the teacher's ESP32 so freshly-deployed students
        # still see real data.
        ESP32_HOST: "__ESP32_HOST__"
        # Pi hostname (otlab-student-NN / otlab-teacher) substituted by
        # render-topology.sh so the "this Pi" card in the dashboard uses
        # the real host name instead of the container's default name.
        PI_HOSTNAME: "__PI_HOSTNAME__"
        # Dashboard is at L3 (operator surface) but co-located with DMZ
        # services for V1 simplicity. Real-plant equivalent: dashboard
        # is the "operator HMI" surface that talks down through the
        # firewall to PCN devices.
      binds:
        # Read-only mount of Suricata's EVE JSON log so the dashboard's
        # IDS Alerts panel can tail it. Suricata runs on the host (not
        # containerized in V1).
        - /var/log/suricata:/var/log/suricata:ro
        # SSH keypair for reaching the physical Pis (system health,
        # remote reboot, pcap capture). Generated once by
        # install-virtual-lab.sh; pubkey is authorized on each physical
        # Pi during install. Mounted RW so SSH can write to known_hosts
        # on first connect.
        - /var/lib/otlab/ssh:/root/.ssh
        # Read-only mount of modbus-master's tick state file. Dashboard
        # reads it every probe_fast() pass to show live poll rate +
        # last-read register values. Same path on both sides — see
        # MM_STATE_PATH in dashboard.py.
        - /var/lib/otlab/mm-state:/var/lib/otlab/mm-state:ro
        # Firewall state exporter — iptables.json + conntrack.txt +
        # dnsmasq-fw.log. Powers the Firewall tab in the dashboard.
        - /var/lib/otlab/fw-state:/var/lib/otlab/fw-state:ro
        # Per-zone DHCP server state — leases, reservations, transaction
        # log. Each path on the dashboard side is just a read-only
        # mirror of what dhcp-dmz and dhcp-pcn write.
        - /var/lib/otlab/dhcp-dmz.leases:/var/lib/otlab/dhcp-dmz.leases:ro
        - /var/lib/otlab/dhcp-pcn.leases:/var/lib/otlab/dhcp-pcn.leases:ro
        - /var/lib/otlab/dhcp-dmz.reservations:/var/lib/otlab/dhcp-dmz.reservations:ro
        - /var/lib/otlab/dhcp-pcn.reservations:/var/lib/otlab/dhcp-pcn.reservations:ro
        - /var/lib/otlab/dhcp-dmz.log:/var/lib/otlab/dhcp-dmz.log:ro
        - /var/lib/otlab/dhcp-pcn.log:/var/lib/otlab/dhcp-pcn.log:ro
      exec:
        # Bring up the DMZ-side interface and assign IP
        - ip link set eth1 up
        - ip addr add __DMZ_NET__.40/24 dev eth1
        # Route to PCN via the firewall (default route stays via clab mgmt
        # for image pulls / NAT egress; cross-zone goes through fw-dmz-pcn)
        - ip route add __PCN_NET__.0/24 via __DMZ_NET__.1

    # V2 stubs (commented — uncomment when bringing those services online):
    #
    # authentik-server:
    #   kind: linux
    #   image: ghcr.io/goauthentik/server:latest
    #   ports: ["9443:9443"]
    #
    # authentik-worker:
    #   kind: linux
    #   image: ghcr.io/goauthentik/server:latest
    #   command: worker
    #
    # ignition:
    #   kind: linux
    #   image: inductiveautomation/ignition:8.1.40
    #   ports: ["8088:8088", "8043:8043"]
    #   env:
    #     ACCEPT_IGNITION_EULA: "Y"
    #     IGNITION_EDITION: maker
    #
    # guacamole:
    #   kind: linux
    #   image: guacamole/guacamole:1.5.5
    #   ports: ["8443:8080"]
    #
    # suricata:
    #   kind: linux
    #   image: jasonish/suricata:latest
    #   capabilities: [NET_ADMIN, SYS_NICE, NET_RAW]
    #   network-mode: container:fw-dmz-pcn   # share the firewall netns to sniff inline

    # ── PCN services (Level 1/2) ────────────────────────────────────────

    plc-1-virt:
      # Virtual OpenPLC #1 — runs the master role (polls outstations).
      # OpenPLC web UI on host port 8081.
      kind: linux
      image: otlab/openplc:latest
      labels:
        zone: pcn
        purdue: "L1"
        plc-role: master
      ports:
        - 8081:8080
      exec:
        - ip link set eth1 up
        - ip addr add __PCN_NET__.60/24 dev eth1
        - ip route add __DMZ_NET__.0/24 via __PCN_NET__.1

    plc-2-virt:
      # Virtual OpenPLC #2 — outstation role.
      kind: linux
      image: otlab/openplc:latest
      labels:
        zone: pcn
        purdue: "L1"
        plc-role: outstation
      ports:
        - 8082:8080
      exec:
        - ip link set eth1 up
        - ip addr add __PCN_NET__.61/24 dev eth1
        - ip route add __DMZ_NET__.0/24 via __PCN_NET__.1

    modbus-master:
      # Purpose-built Modbus TCP master polling sensor-sim every 100 ms.
      # Replaces OpenPLC for the on-the-wire master role; plc-1-virt /
      # plc-2-virt's OpenPLC web UIs are still useful for IEC 61131-3
      # click-around lessons, but the actual master traffic comes from
      # here (deterministic + observable).
      #
      # IP: __PCN_NET__.43 — placed in the .40-.49 "L1 PLCs" range per
      # naming-schema.md, alongside physical l1-plc-01 (.47). Originally
      # was .50, but that collides with Conpot's Siemens persona on
      # l1-hp-01's macvlan (also .50) once the physical segment is
      # bridged into pcn-br0 via eth1.
      kind: linux
      image: otlab/modbus-master:latest
      labels:
        zone: pcn
        purdue: "L1"
        service: modbus-master
        plc-role: master
      env:
        SLAVE_IP: "__PCN_NET__.70"
        SLAVE_PORT: "5020"
        POLL_PERIOD_S: "0.1"
        # Tick state written here every LOG_INTERVAL_S seconds so the
        # dashboard can show live poll rate + last-read register values
        # without scraping container logs or running tcpdump.
        STATE_FILE: "/var/lib/otlab/mm-state/last.json"
        # Secondary slave: the Modbus gateway in front of the ESP32.
        # Polled at 1 Hz (every 10 main ticks at 100 ms each). Disabled
        # by leaving GATEWAY_IP empty.
        GATEWAY_IP: "__PCN_NET__.180"
        GATEWAY_PORT: "502"
        GATEWAY_HR_COUNT: "6"
        GATEWAY_POLL_EVERY_N: "10"
      binds:
        # Shared with the dashboard (read-only on its end). Host path
        # lives under /var/lib/otlab so it persists across clab redeploys
        # and is visible from `cat` on the host for debugging.
        - /var/lib/otlab/mm-state:/var/lib/otlab/mm-state
      exec:
        - ip link set eth1 up
        - ip addr add __PCN_NET__.43/24 dev eth1
        - ip route add __DMZ_NET__.0/24 via __PCN_NET__.1

    sensor-sim:
      kind: linux
      image: otlab/sensor-sim:latest
      labels:
        zone: pcn
        purdue: "L1"
        service: sensor-sim
      env:
        SCENARIO: water-treatment
        LISTEN_HOST: "0.0.0.0"
        LISTEN_PORT: "5020"
        CTRL_PORT: "5021"
      exec:
        - ip link set eth1 up
        - ip addr add __PCN_NET__.70/24 dev eth1
        # Route back to DMZ via the firewall — only used for return
        # traffic since PCN never initiates to DMZ (firewall blocks that).
        - ip route add __DMZ_NET__.0/24 via __PCN_NET__.1

    dnp3-outstation:
      kind: linux
      image: otlab/dnp3-outstation:latest
      labels:
        zone: pcn
        purdue: "L1"
        service: dnp3-outstation
      env:
        SCENARIO: water-treatment
        LISTEN_PORT: "20000"
      exec:
        - ip link set eth1 up
        - ip addr add __PCN_NET__.71/24 dev eth1
        - ip route add __DMZ_NET__.0/24 via __PCN_NET__.1

    # ── Modbus TCP gateway — translates the ESP32 (IoT) into Modbus
    # registers polled by OpenPLC / modbus-master / sensor-sim. Real-OT
    # pedagogy: this is the canonical IoT-to-OT bridge pattern. See
    # gateway/README.md for the register map + add-sensor workflow.
    #
    # Egress to the ESP32 (on classroom WiFi 10.20.30.x) routes
    # outbound via the firewall container's MASQUERADE.
    modbus-gateway:
      kind: linux
      image: otlab/modbus-gateway:latest
      labels:
        zone: pcn
        purdue: "L1/L2"
        service: modbus-gateway
      env:
        # ESP32_HOST — IP of the per-student ESP32 on classroom WiFi.
        # Defaults to the teacher's ESP32 (10.20.30.201) until each
        # student's ESP32 is flashed; override per-deploy via:
        #   docker run -e ESP32_HOST=10.20.30.20X ...
        ESP32_HOST: "__ESP32_HOST__"
        MODBUS_LISTEN_PORT: "502"
        POLL_INTERVAL_S: "1.0"
      exec:
        - ip link set eth1 up
        - ip addr add __PCN_NET__.180/24 dev eth1
        - ip route add __DMZ_NET__.0/24 via __PCN_NET__.1
        # Default route via firewall → eth0 → classroom segment → ESP32
        - ip route add default via __PCN_NET__.1

    # ── DHCP servers — one per zone ─────────────────────────────────────
    # Each is a thin wrapper around dnsmasq running in DHCP-only mode
    # (port=0). They advertise the firewall container (.1 in each zone)
    # as both the default gateway (DHCP option 3) and the DNS server
    # (DHCP option 6) — the firewall runs dnsmasq as a DNS forwarder
    # for the upstream resolvers.
    #
    # Why two containers? Dnsmasq prefers one process per interface for
    # DHCP, and keeping per-zone configs tidy is easier than juggling
    # a single dual-homed daemon. Same image, different env.
    #
    # Scopes (per docs/naming-schema.md):
    #   DMZ __DMZ_NET__.0/24   .150 -- .199   (50 leases)
    #   PCN __PCN_NET__.0/24     .200 -- .250   (51 leases)
    # Static reservations live above the scope (e.g. .43, .47, .60, .70).

    dhcp-dmz:
      kind: linux
      image: otlab/dhcp:latest
      labels:
        zone: dmz
        purdue: "L3.5"
        service: dhcp
      # Docker's default capabilities (include NET_RAW for the ICMP
      # probes + raw DHCP sockets) are sufficient for dnsmasq running
      # as root. ContainerLab v0.59 doesn't expose a `capabilities:`
      # node field — if extra caps become necessary, set them with
      # `docker run --cap-add` after deploy or upgrade clab.
      binds:
        # Bind-mount the lease database file to a host-shared path so
        # the dashboard container can read it directly. We use a file-
        # bind (not dir) so dnsmasq's leasefile rename-on-update stays
        # atomic. The host file is created lazily by the entrypoint if
        # missing.
        - /var/lib/otlab/dhcp-dmz.leases:/var/lib/dnsmasq/leases
        # Reservations file (rendered from DHCP_HOSTS at start) +
        # transaction log — both written here and read by the dashboard.
        - /var/lib/otlab/dhcp-dmz.reservations:/var/lib/dnsmasq/reservations
        - /var/lib/otlab/dhcp-dmz.log:/var/log/dnsmasq.log
      env:
        LEASE_FILE:   "/var/lib/dnsmasq/leases"
        RESERVATIONS_FILE: "/var/lib/dnsmasq/reservations"
        LISTEN_IF:    "eth1"
        NETWORK:      "__DMZ_NET__.0"
        NETMASK:      "255.255.255.0"
        PREFIX:       "24"
        SELF_IP:      "__DMZ_NET__.2"
        GATEWAY:      "__DMZ_NET__.1"
        DNS_SERVER:   "__DMZ_NET__.1"
        RANGE_START:  "__DMZ_NET__.150"
        RANGE_END:    "__DMZ_NET__.199"
        LEASE_TIME:   "12h"
        DOMAIN:       "otlab.local"
        LOG_DHCP:     "1"
        # DMZ reservations — currently empty (the dashboard, Ignition,
        # Authentik, etc. all run as containers with clab-assigned
        # static IPs in the .10–.49 range, not via DHCP). When operator
        # laptops or other physical devices land on the wire and want
        # sticky IPs, add them here. Format same as dhcp-pcn.
        #
        # Example:
        #   DHCP_HOSTS: |
        #     20:4e:7f:34:ff:65,operator-laptop,__DMZ_NET__.100
        DHCP_HOSTS: ""
      exec:
        # Belt-and-suspenders: entrypoint also does this, but having
        # containerlab assign the IP means inspect/topo views see it.
        - ip link set eth1 up
        - ip addr add __DMZ_NET__.2/24 dev eth1
        - ip route add __PCN_NET__.0/24 via __DMZ_NET__.1

    dhcp-pcn:
      kind: linux
      image: otlab/dhcp:latest
      labels:
        zone: pcn
        purdue: "L1/L2"
        service: dhcp
      binds:
        - /var/lib/otlab/dhcp-pcn.leases:/var/lib/dnsmasq/leases
        - /var/lib/otlab/dhcp-pcn.reservations:/var/lib/dnsmasq/reservations
        - /var/lib/otlab/dhcp-pcn.log:/var/log/dnsmasq.log
      env:
        LEASE_FILE:   "/var/lib/dnsmasq/leases"
        RESERVATIONS_FILE: "/var/lib/dnsmasq/reservations"
        LISTEN_IF:    "eth1"
        NETWORK:      "__PCN_NET__.0"
        NETMASK:      "255.255.255.0"
        PREFIX:       "24"
        SELF_IP:      "__PCN_NET__.2"
        GATEWAY:      "__PCN_NET__.1"
        DNS_SERVER:   "__PCN_NET__.1"
        RANGE_START:  "__PCN_NET__.200"
        RANGE_END:    "__PCN_NET__.250"
        LEASE_TIME:   "12h"
        DOMAIN:       "otlab.local"
        LOG_DHCP:     "1"
        # Static reservations — keep known devices on their canonical
        # IPs even if their device-side static config gets clobbered or
        # if they're booted clean from an SD card. The address plan in
        # docs/naming-schema.md is the source of truth for these.
        #
        # Format (one per line, dnsmasq dhcp-host syntax):
        #   <MAC>,<NAME>,<IP>
        #
        # Physical Pis use canonical OUIs (b8:27:eb = RPi Foundation;
        # 2c:cf:67 = Pegatron, used by Pi 5 onboard NIC). Conpot
        # personas use Docker's IP-derived MAC scheme (02:42:0a:14:1e:NN
        # where NN = last octet) which is deterministic across rebuilds.
        DHCP_HOSTS: |
          2c:cf:67:4f:d3:09,l1-plc-01,__PCN_NET__.47
          b8:27:eb:78:85:77,l1-hp-01,__PCN_NET__.48
          02:42:0a:14:1e:32,siemens-PS4,__PCN_NET__.50
          02:42:0a:14:1e:33,schneider-M340,__PCN_NET__.51
          02:42:0a:14:1e:34,rockwell-CHEM,__PCN_NET__.52
      exec:
        - ip link set eth1 up
        - ip addr add __PCN_NET__.2/24 dev eth1
        - ip route add __DMZ_NET__.0/24 via __PCN_NET__.1

  # ───────────────────────────────────────────────────────────────────────
  # Links — veth pairs between containers and bridges. Each container
  # gets one PCN/DMZ-side interface (eth1).
  # ───────────────────────────────────────────────────────────────────────
  links:
    # Firewall straddles both bridges (conduit between zones)
    - endpoints: ["fw-dmz-pcn:eth1", "dmz-br0:fw-dmz"]
    - endpoints: ["fw-dmz-pcn:eth2", "pcn-br0:fw-pcn"]

    # DMZ
    - endpoints: ["dashboard:eth1", "dmz-br0:dashboard"]
    - endpoints: ["dhcp-dmz:eth1",  "dmz-br0:dhcpdmz"]

    # PCN
    - endpoints: ["modbus-master:eth1",   "pcn-br0:master"]
    - endpoints: ["plc-1-virt:eth1",      "pcn-br0:plc1"]
    - endpoints: ["plc-2-virt:eth1",      "pcn-br0:plc2"]
    - endpoints: ["sensor-sim:eth1",      "pcn-br0:sensorsim"]
    - endpoints: ["dnp3-outstation:eth1", "pcn-br0:dnp3"]
    - endpoints: ["dhcp-pcn:eth1",        "pcn-br0:dhcppcn"]
    - endpoints: ["modbus-gateway:eth1",  "pcn-br0:gateway"]
