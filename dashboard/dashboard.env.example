# OTLab dashboard runtime config. Copy to dashboard.env on the Pi.
# Keep secrets out of the repo — this file is the example template.
#
# The lab's web UI password convention is intentionally-public 'P@ssw0rd!'
# to match MFCTP and OpenPLC. Rotate per DEF CON event.

DASH_USER=otlab
DASH_PASS=P@ssw0rd!

# Probe pacing — defaults are sensible for a Pi 5.
PROBE_INTERVAL=2.5
PROBE_TIMEOUT=1.5

# HTTPS port (avoid OpenPLC's :8080 and the REST API's :8443).
LISTEN_PORT=8000

# SSH user the dashboard reaches out as for remote reboots. Must have
# NOPASSWD sudo on the target Pi (otadmin is canonical).
SSH_USER=otadmin

# Lab credentials surfaced through the at-a-glance creds panel. All
# intentionally-public per project convention; rotate per DEF CON event.
WIFI_SSID=MFCTP
WIFI_PASS=P@ssw0rd!
OPENPLC_USER_NAME=openplc
OPENPLC_USER_PASS=P@ssw0rd!
