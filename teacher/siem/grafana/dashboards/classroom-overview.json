          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "title": "Suricata alerts per student (last 5 min)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (student_id) (count_over_time({job=\"suricata\", event_type=\"alert\"}[5m]))",
          "legendFormat": "student-{{student_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "title": "Top Suricata signatures (last 30 min)",
      "type": "logs",
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{job=\"suricata\", event_type=\"alert\"} | json | line_format \"student-{{.student_id}}  {{.alert_signature}}  src={{.src_ip}} dst={{.dest_ip}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 4,
      "title": "Recent firewall denies",
      "type": "logs",
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{job=\"otlab-firewall\"} |= \"DROP\"",
          "refId": "A"
        }
      ]
    }
